{
  "name": "one-minute-bible",
  "private": true,
  "scripts": {
    "dev:server": "pnpm --dir server run dev",
    "dev:web": "pnpm --dir apps/web exec nuxt dev --port 7711",
    "build:server": "pnpm --dir server run build",
    "build:web": "pnpm --dir apps/web run build",
    "build:all": "pnpm run build:server && pnpm run build:web",
    "start:server": "pnpm --dir server run start",
    "start:web": "pnpm --dir apps/web run start",
    "install:all": "pnpm --dir server install && pnpm --dir apps/web install"
  }
}
